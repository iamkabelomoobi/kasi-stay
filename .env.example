APP_NAME=kasistay
NODE_ENV=development
PORT=4000
SERVER_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
RENTER_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kasistay

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=kasistay:
REDIS_CONNECT_TIMEOUT_MS=10000
PROPERTY_SEARCH_CACHE_TTL_SECONDS=60
PROPERTY_VIEW_DEBOUNCE_TTL_SECONDS=86400

SEARCH_PROVIDER=elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=kasistay-
ELASTICSEARCH_PROPERTY_INDEX=properties
ELASTICSEARCH_REQUEST_TIMEOUT_MS=10000

STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_UPLOAD_URL_TTL_SECONDS=900

QUEUE_DRIVER=memory
QUEUE_NAME=kasistay-server
QUEUE_RETRY_ATTEMPTS=3
QUEUE_BACKOFF_STRATEGY=exponential
QUEUE_BACKOFF_DELAY_MS=1000
QUEUE_POLL_INTERVAL_MS=500
QUEUE_WORKER_CONCURRENCY=5
PROPERTY_EXPIRY_JOB_INTERVAL_MS=86400000
LISTING_BOOST_EXPIRY_JOB_INTERVAL_MS=86400000
SAVED_SEARCH_ALERT_JOB_INTERVAL_MS=21600000

MAIL_PROVIDER=mailhog
MAILHOG_HOST=localhost
MAILHOG_PORT=1025
MAILHOG_SECURE=false
MAILHOG_USER=
MAILHOG_PASS=
MAILHOG_FROM=kasistay <no-reply@kasistay.local>
RESEND_API_KEY=
RESEND_FROM=

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_PROCESS_URL=
PAYFAST_VALIDATE_URL=

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator pothos {
  provider = "prisma-pothos-types"
  output   = "../generated/pothos-types.ts"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AGENT
  OWNER
  BUYER
  RENTER
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SOLD
  RENTED
}

enum ListingType {
  BUY
  RENT
  SELL
}

enum PropertyType {
  APARTMENT
  VILLA
  TOWNHOUSE
  STUDIO
  PENTHOUSE
  LAND
  COMMERCIAL
}

enum PriceFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONCE
}

enum Furnishing {
  FURNISHED
  SEMI
  UNFURNISHED
}

enum OccupancyStatus {
  VACANT
  OCCUPIED
}

enum PropertyMediaType {
  IMAGE
  VIDEO
  FLOOR_PLAN
  VIRTUAL_TOUR
}

enum PropertyDocumentType {
  TITLE_DEED
  NOC
  BROCHURE
  VALUATION
  OTHER
}

enum AmenityCategory {
  BUILDING
  UNIT
  VIEW
  ACCESSIBILITY
}

enum OwnershipType {
  FREEHOLD
  LEASEHOLD
}

enum BuyOwnerType {
  INDIVIDUAL
  COMPANY
  JOINT
}

enum TenantPreference {
  FAMILY
  SINGLE
  ANY
}

enum MaintenanceBy {
  LANDLORD
  TENANT
}

enum SellerType {
  OWNER
  AGENT
  DEVELOPER
}

enum CommissionPaidBy {
  BUYER
  SELLER
}

enum InquirySource {
  ORGANIC
  PAID
  REFERRAL
}

enum InquiryStatus {
  NEW
  CONTACTED
  VIEWING
  OFFER
  CLOSED
}

enum ViewingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReportReason {
  FRAUD
  DUPLICATE
  INACCURATE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum ListingBoostType {
  FEATURED
  TOP
  HOT_DEAL
}

enum RoommateProfileStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GenderIdentity {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum GenderPreference {
  ANY
  MALE
  FEMALE
  NON_BINARY
  OTHER
}

enum MarketplaceCategory {
  FURNITURE
  APPLIANCES
  HOME_DECOR
  ELECTRONICS
  ROOM_ESSENTIALS
  OTHER
}

enum MarketplaceItemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SOLD
}

enum MarketplaceItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  NEEDS_REPAIR
}

enum ServiceCategory {
  CLEANING
  TRANSPORT
  PLUMBING
  ELECTRICAL
  MOVING
  HANDYMAN
  SECURITY
  OTHER
}

enum ServiceProviderStatus {
  PENDING
  ACTIVE
  ARCHIVED
}

enum ServiceListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ServiceRequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum ConversationContextType {
  PROPERTY
  ROOMMATE
  MARKETPLACE_ITEM
  SERVICE
}

enum MessageType {
  TEXT
  SYSTEM
}

enum AttorneyProfileStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleCategoryCode {
  PROPERTY_ADVICE
  PROPERTY_NEWS
  RENTING_GUIDE
  SELLERS_GUIDE
  BUY_TO_LET
  PROPERTY_DEVELOPER
  PROPERTY_FLIPPING
  LIFESTYLE_DECOR
  NEIGHBOURHOOD
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StaticPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StaticPageType {
  ABOUT_US
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS
  COOKIE_POLICY
  PAIA_MANUAL
  CUSTOM
}

enum CareerPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum ApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  passwordHash  String?
  role          UserRole @default(RENTER)
  avatar        String?
  isVerified    Boolean  @default(false)
  refreshToken  String?
  agencyId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agency                    Agency?                    @relation("AgencyAgents", fields: [agencyId], references: [id], onDelete: SetNull)
  ownedAgencies             Agency[]                   @relation("AgencyOwner")
  listedProperties          Property[]                 @relation("PropertyAgent")
  inquiries                 Inquiry[]
  viewings                  Viewing[]
  savedProperties           SavedProperty[]
  savedSearches             SavedSearch[]
  notifications             Notification[]
  reviews                   Review[]
  reports                   Report[]
  subscriptions             AgentSubscription[]        @relation("AgentSubscriptions")
  boosts                    ListingBoost[]             @relation("AgentBoosts")
  roommateProfile           RoommateProfile?
  savedRoommateProfiles     RoommateSavedProfile[]
  marketplaceItems          MarketplaceItem[]          @relation("MarketplaceItemOwner")
  savedMarketplaceItems     MarketplaceSavedItem[]
  serviceProvider           ServiceProvider?
  serviceRequests           ServiceRequest[]           @relation("ServiceRequester")
  conversationParticipants  ConversationParticipant[]
  sentMessages              Message[]                  @relation("MessageSender")
  createdConversations      Conversation[]             @relation("ConversationCreator")
  attorneyProfilesCreated   AttorneyProfile[]          @relation("AttorneyProfileCreator")
  articles                  Article[]                  @relation("ArticleAuthor")
  staticPagesCreated        StaticPage[]               @relation("StaticPageCreator")
  careerPostsCreated        CareerPost[]               @relation("CareerPostCreator")
  jobApplications           JobApplication[]
  contactMessages           ContactMessage[]
  agentApplications         AgentApplication[]
  agencyAdvertisingRequests AgencyAdvertisingRequest[]

  admin  Admin?
  renter Renter?

  sessions Session[]
  accounts Account[]

  @@index([role])
  @@index([agencyId])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin")
}

model Renter {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("renter")
}

model Agency {
  id            String     @id @default(cuid())
  name          String
  logo          String?
  licenseNumber String?    @unique
  ownerId       String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  owner         User       @relation("AgencyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  agents        User[]     @relation("AgencyAgents")
  listings      Property[]

  @@index([ownerId])
}

model Property {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String?
  status          PropertyStatus   @default(DRAFT)
  listingType     ListingType
  propertyType    PropertyType
  price           Decimal?         @db.Decimal(12, 2)
  currency        String           @default("ZAR")
  priceFrequency  PriceFrequency   @default(ONCE)
  bedrooms        Int?
  bathrooms       Int?
  parkingSpaces   Int?
  builtUpArea     Float?
  plotArea        Float?
  floorNumber     Int?
  totalFloors     Int?
  yearBuilt       Int?
  furnishing      Furnishing?
  occupancyStatus OccupancyStatus?
  availableFrom   DateTime?
  agentId         String?
  agencyId        String?
  views           Int              @default(0)
  isFeatured      Boolean          @default(false)
  isVerified      Boolean          @default(false)
  permitNumber    String?
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  agent        User?              @relation("PropertyAgent", fields: [agentId], references: [id], onDelete: SetNull)
  agency       Agency?            @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  location     Location?
  amenities    PropertyAmenity[]
  media        PropertyMedia[]
  documents    PropertyDocument[]
  buyDetail    BuyDetail?
  rentDetail   RentDetail?
  sellDetail   SellDetail?
  priceHistory PriceHistory[]
  inquiries    Inquiry[]
  viewings     Viewing[]
  savedBy      SavedProperty[]
  reviews      Review[]
  reports      Report[]
  boosts       ListingBoost[]

  @@index([status])
  @@index([listingType])
  @@index([propertyType])
  @@index([price])
  @@index([agentId])
  @@index([agencyId])
  @@index([expiresAt])
  @@index([createdAt])
}

model Location {
  id           String   @id @default(cuid())
  propertyId   String   @unique
  address      String
  city         String
  state        String?
  country      String
  postalCode   String?
  latitude     Float?
  longitude    Float?
  neighborhood String?
  geoJson      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([country])
  @@index([latitude, longitude])
}

model PropertyMedia {
  id         String            @id @default(cuid())
  propertyId String
  url        String
  type       PropertyMediaType @default(IMAGE)
  order      Int               @default(0)
  isPrimary  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  property   Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyDocument {
  id         String               @id @default(cuid())
  propertyId String
  url        String
  type       PropertyDocumentType @default(OTHER)
  label      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  property   Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Amenity {
  id         String            @id @default(cuid())
  name       String            @unique
  category   AmenityCategory
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([amenityId])
}

model BuyDetail {
  id                String         @id @default(cuid())
  propertyId        String         @unique
  ownership         OwnershipType?
  ownerType         BuyOwnerType?
  isDeveloper       Boolean        @default(false)
  developerName     String?
  projectName       String?
  handoverDate      DateTime?
  registrationInfo  String?
  titleDeedVerified Boolean        @default(false)
  roi               Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  property          Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  paymentPlan       PaymentPlan?
}

model RentDetail {
  id                String            @id @default(cuid())
  propertyId        String            @unique
  depositAmount     Decimal?          @db.Decimal(12, 2)
  minLeaseTerm      Int?
  tenantPreference  TenantPreference?
  petsAllowed       Boolean           @default(false)
  utilitiesIncluded Boolean           @default(false)
  chillerIncluded   Boolean           @default(false)
  cheques           Int?
  maintenanceBy     MaintenanceBy?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model SellDetail {
  id               String            @id @default(cuid())
  propertyId       String            @unique
  sellerType       SellerType?
  isOffMarket      Boolean           @default(false)
  commissionPaidBy CommissionPaidBy?
  inspectionStatus String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  priceHistory     PriceHistory[]
}

model PriceHistory {
  id           String      @id @default(cuid())
  propertyId   String
  sellDetailId String?
  price        Decimal     @db.Decimal(12, 2)
  changedAt    DateTime    @default(now())
  property     Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sellDetail   SellDetail? @relation(fields: [sellDetailId], references: [id], onDelete: SetNull)

  @@index([propertyId, changedAt])
  @@index([sellDetailId])
}

model PaymentPlan {
  id           String        @id @default(cuid())
  buyDetailId  String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  buyDetail    BuyDetail     @relation(fields: [buyDetailId], references: [id], onDelete: Cascade)
  installments Installment[]
}

model Installment {
  id            String      @id @default(cuid())
  paymentPlanId String
  dueDate       DateTime
  amount        Decimal     @db.Decimal(12, 2)
  percentage    Float?
  label         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@index([paymentPlanId])
}

model Inquiry {
  id         String        @id @default(cuid())
  propertyId String
  userId     String?
  name       String
  email      String
  phone      String?
  message    String?
  source     InquirySource @default(ORGANIC)
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  viewings   Viewing[]

  @@index([propertyId])
  @@index([userId])
  @@index([status])
}

model Viewing {
  id          String        @id @default(cuid())
  inquiryId   String
  propertyId  String
  userId      String
  scheduledAt DateTime
  status      ViewingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  inquiry     Inquiry       @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([propertyId])
  @@index([userId])
  @@index([status])
}

model SavedProperty {
  userId     String
  propertyId String
  savedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([propertyId])
}

model SavedSearch {
  id             String    @id @default(cuid())
  userId         String
  filters        Json
  alertEnabled   Boolean   @default(true)
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([alertEnabled])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Review {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([userId])
}

model Report {
  id          String       @id @default(cuid())
  propertyId  String
  userId      String
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model SubscriptionPlan {
  id            String              @id @default(cuid())
  name          String
  price         Decimal             @db.Decimal(12, 2)
  features      Json?
  listingLimit  Int
  boostCredits  Int
  durationDays  Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  subscriptions AgentSubscription[]
}

model AgentSubscription {
  id        String           @id @default(cuid())
  agentId   String
  planId    String
  startsAt  DateTime
  expiresAt DateTime
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  agent     User             @relation("AgentSubscriptions", fields: [agentId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([planId])
  @@index([isActive, expiresAt])
}

model ListingBoost {
  id         String           @id @default(cuid())
  propertyId String
  agentId    String
  type       ListingBoostType
  startsAt   DateTime
  expiresAt  DateTime
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent      User             @relation("AgentBoosts", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([agentId])
  @@index([expiresAt])
}

model RoommateProfile {
  id              String                 @id @default(cuid())
  userId          String                 @unique
  headline        String?
  bio             String?
  age             Int?
  occupation      String?
  city            String
  area            String?
  budgetMin       Decimal?               @db.Decimal(12, 2)
  budgetMax       Decimal?               @db.Decimal(12, 2)
  currency        String                 @default("ZAR")
  moveInDate      DateTime?
  gender          GenderIdentity?
  preferredGender GenderPreference?
  smokingFriendly Boolean                @default(false)
  petsFriendly    Boolean                @default(false)
  photoUrl        String?
  status          RoommateProfileStatus  @default(PUBLISHED)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedBy         RoommateSavedProfile[]

  @@index([userId])
  @@index([status])
  @@index([city])
  @@index([moveInDate])
  @@index([preferredGender])
}

model RoommateSavedProfile {
  userId    String
  profileId String
  savedAt   DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   RoommateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([userId, profileId])
  @@index([profileId])
}

model MarketplaceItem {
  id           String                   @id @default(cuid())
  ownerId      String
  title        String
  slug         String                   @unique
  description  String?
  category     MarketplaceCategory
  status       MarketplaceItemStatus    @default(DRAFT)
  condition    MarketplaceItemCondition @default(GOOD)
  price        Decimal?                 @db.Decimal(12, 2)
  currency     String                   @default("ZAR")
  city         String
  locationText String?
  imageUrls    Json?
  isNegotiable Boolean                  @default(false)
  publishedAt  DateTime?
  archivedAt   DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  owner        User                     @relation("MarketplaceItemOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  savedBy      MarketplaceSavedItem[]

  @@index([ownerId])
  @@index([category])
  @@index([status])
  @@index([city])
  @@index([price])
  @@index([createdAt])
}

model MarketplaceSavedItem {
  userId  String
  itemId  String
  savedAt DateTime        @default(now())
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([itemId])
}

model ServiceProvider {
  id           String                @id @default(cuid())
  userId       String                @unique
  businessName String
  slug         String                @unique
  description  String?
  email        String?
  phone        String?
  city         String
  serviceArea  String?
  logoUrl      String?
  status       ServiceProviderStatus @default(ACTIVE)
  isVerified   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings     ServiceListing[]

  @@index([userId])
  @@index([status])
  @@index([city])
}

model ServiceListing {
  id            String               @id @default(cuid())
  providerId    String
  title         String
  slug          String               @unique
  description   String?
  category      ServiceCategory
  status        ServiceListingStatus @default(PUBLISHED)
  startingPrice Decimal?             @db.Decimal(12, 2)
  currency      String               @default("ZAR")
  city          String
  serviceArea   String?
  imageUrls     Json?
  publishedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  provider      ServiceProvider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  requests      ServiceRequest[]

  @@index([providerId])
  @@index([category])
  @@index([status])
  @@index([city])
  @@index([createdAt])
}

model ServiceRequest {
  id            String               @id @default(cuid())
  listingId     String
  requesterId   String
  message       String?
  preferredDate DateTime?
  status        ServiceRequestStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  listing       ServiceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requester     User                 @relation("ServiceRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([requesterId])
  @@index([status])
}

model Conversation {
  id            String                    @id @default(cuid())
  createdById   String
  subject       String?
  contextType   ConversationContextType?
  contextId     String?
  lastMessageAt DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  createdBy     User                      @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([createdById])
  @@index([contextType, contextId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  archivedAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, archivedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  type           MessageType  @default(TEXT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model AttorneyProfile {
  id          String                @id @default(cuid())
  slug        String                @unique
  name        String
  firmName    String?
  description String?
  city        String
  email       String?
  phone       String?
  websiteUrl  String?
  imageUrl    String?
  status      AttorneyProfileStatus @default(DRAFT)
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   User?                 @relation("AttorneyProfileCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([city])
}

model ArticleCategory {
  id        String              @id @default(cuid())
  code      ArticleCategoryCode @unique
  name      String
  slug      String              @unique
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  articles  Article[]
}

model Article {
  id            String          @id @default(cuid())
  categoryId    String
  authorId      String?
  title         String
  slug          String          @unique
  summary       String?
  content       String
  coverImageUrl String?
  status        ArticleStatus   @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author        User?           @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model StaticPage {
  id          String           @id @default(cuid())
  slug        String           @unique
  type        StaticPageType   @default(CUSTOM)
  title       String
  summary     String?
  content     String
  status      StaticPageStatus @default(DRAFT)
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   User?            @relation("StaticPageCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
}

model CareerPost {
  id             String           @id @default(cuid())
  slug           String           @unique
  title          String
  summary        String?
  description    String
  location       String?
  employmentType String?
  status         CareerPostStatus @default(DRAFT)
  publishedAt    DateTime?
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      User?            @relation("CareerPostCreator", fields: [createdById], references: [id], onDelete: SetNull)
  applications   JobApplication[]

  @@index([status])
  @@index([createdAt])
}

model JobApplication {
  id           String     @id @default(cuid())
  careerPostId String
  userId       String
  fullName     String
  email        String
  phone        String?
  coverLetter  String?
  resumeUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  careerPost   CareerPost @relation(fields: [careerPostId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([careerPostId, userId])
  @@index([careerPostId])
  @@index([userId])
}

model ContactMessage {
  id        String               @id @default(cuid())
  userId    String
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AgentApplication {
  id              String                  @id @default(cuid())
  userId          String
  phone           String?
  city            String?
  experience      String?
  licenseNumber   String?
  motivation      String?
  status          ApplicationReviewStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AgencyAdvertisingRequest {
  id              String                  @id @default(cuid())
  userId          String
  agencyName      String
  contactEmail    String
  contactPhone    String?
  websiteUrl      String?
  budget          String?
  message         String?
  status          ApplicationReviewStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
